# ===== MiniMax =====
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io
# Optional override; if empty, backend will use its internal default model
MINIMAX_TEXT_MODEL=

# ===== OpenAI embeddings (for semantic dedupe candidate retrieval) =====
OPENAI_API_KEY=
# Optional alias; used if OPENAI_API_KEY is empty.
OPENAI_EMBEDDING_API_KEY=
# Optional highest-priority alias for this pipeline only.
INTEL_OPENAI_EMBEDDING_API_KEY=
INTEL_KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
INTEL_DEDUPE_EMBEDDING_ENABLED=1
# Candidate threshold is intentionally recall-oriented; final dedupe still
# requires strong similarity, same-date support, or high term overlap.
INTEL_DEDUPE_EMBEDDING_CANDIDATE_THRESHOLD=0.62
INTEL_DEDUPE_EMBEDDING_STRONG_THRESHOLD=0.86
INTEL_DEDUPE_EMBEDDING_SAME_DATE_THRESHOLD=0.74
INTEL_DEDUPE_EMBEDDING_TERM_THRESHOLD=0.68
INTEL_DEDUPE_EMBEDDING_BATCH_SIZE=40
INTEL_DEDUPE_EMBEDDING_TIMEOUT_SECONDS=80
INTEL_KNOWLEDGE_EMBEDDING_BATCH_SIZE=40
INTEL_KNOWLEDGE_EMBEDDING_TIMEOUT_SECONDS=80
# Renaiss Agent uses OpenAI embeddings for retrieval and MiniMax for answers.
INTEL_AGENT_MINIMAX_MODEL=MiniMax-M2.7
# Optional. Leave empty to avoid sending a MiniMax max_tokens limit.
INTEL_AGENT_MAX_TOKENS=
INTEL_AGENT_TEMPERATURE=0.2
INTEL_AGENT_MINIMAX_CONNECT_TIMEOUT_SECONDS=15
INTEL_AGENT_MINIMAX_READ_TIMEOUT_SECONDS=80
INTEL_AGENT_EMBEDDING_TIMEOUT_SECONDS=45
INTEL_FEED_MEMORY_RETENTION_DAYS=30
INTEL_FEED_QUEUE_RETENTION_DAYS=30

# ===== Discord monitor (optional) =====
DISCORD_BOT_TOKEN=
DISCORD_MONITOR_ENABLED=1
DISCORD_MONITOR_CHANNEL_IDS=1478788250687766796
DISCORD_MONITOR_LIMIT=80

# ===== Admin auth =====
INTEL_ADMIN_USER=gavinx
# Choose one: INTEL_ADMIN_PASS_HASH (recommended) or INTEL_ADMIN_PASS
INTEL_ADMIN_PASS_HASH=
INTEL_ADMIN_PASS=
INTEL_SESSION_TTL_SECONDS=43200
# Optional token secret for Bearer auth; leave blank to derive from admin credentials.
INTEL_AUTH_TOKEN_SECRET=
INTEL_AUTH_TOKEN_TTL_SECONDS=43200

# ===== Cross-domain cookie/CORS (frontend and backend split) =====
INTEL_ALLOWED_ORIGINS=
INTEL_COOKIE_SAMESITE=None
INTEL_COOKIE_SECURE=1
INTEL_COOKIE_DOMAIN=

# ===== Expo profile auth (Privy) =====
# Required in production when /api/expo-profile/* endpoints are enabled.
PRIVY_APP_ID=
PRIVY_VERIFICATION_KEY=
# Local development only: allows Authorization: Bearer dev:<id>.
EXPO_PROFILE_DEV_AUTH=0

# ===== Expo profile cloud storage =====
# Production should use Postgres. Local dev can leave this empty to use SQLite.
EXPO_PROFILE_DATABASE_URL=
# Supported aliases if your host injects them:
# DATABASE_URL= / POSTGRES_URI= / POSTGRES_CONNECTION_STRING=

# ===== Server runtime =====
HOST=0.0.0.0
PORT=8787
NEWS_INTERVAL_MINUTES=60
NEWS_LANGS=zh-Hant

# ===== Persistent data (Git-backed restore) =====
APP_ENV=server
WEBSITE_DATA_ROOT=/data/RENAISS_WEBSITE
WEBSITE_DATA_MIGRATE_ONCE=1
WEBSITE_DATA_RESTORE_ON_STARTUP=0
# restore is manual via admin button (/api/intel/restore)
WEBSITE_DATA_RESTORE_POLICY=always
WEBSITE_DATA_RESTORE_FORCE=0
I18N_FEED_FALLBACK_MODE=base

# ===== Data backup repo (read at startup; write disabled by default) =====
WEBSITE_BACKUP_ENABLED=0
WEBSITE_BACKUP_PROVIDER=git
WEBSITE_BACKUP_REPO=https://github.com/Gavinzip/webdata.git
WEBSITE_BACKUP_BRANCH=main
WEBSITE_BACKUP_SUBDIR=RENAISS_WEBSITE
WEBSITE_BACKUP_REPO_DIR=/data/.renaiss_website_data_repo
WEBSITE_BACKUP_TIMEZONE=Asia/Taipei
WEBSITE_BACKUP_HOUR=0
WEBSITE_BACKUP_MINUTE=10
